<Window x:Class="CarWikipedia.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Car Wikipedia"
        Height="720"
        MinHeight="560"
        Width="1180"
        MinWidth="900">
    <DockPanel Background="#F7F7F5">
        <ToolBar DockPanel.Dock="Top" Padding="8,6">
            <Button Content="저장소 열기" Padding="12,6" Click="OpenRepositoryButton_Click" />
            <Button Content="새 문서" Padding="12,6" Click="NewDocumentButton_Click" />
            <Button Content="새 폴더" Padding="12,6" Click="NewFolderButton_Click" />
            <Button Content="DOCX 가져오기" Padding="12,6" />
            <Separator />
            <Button x:Name="EditModeButton" Content="편집" Padding="12,6" Click="EditModeButton_Click" />
            <Button Content="저장" Padding="12,6" Click="SaveButton_Click" />
            <Button Content="이동" Padding="12,6" Click="MoveButton_Click" />
            <Button Content="삭제" Padding="12,6" Click="DeleteButton_Click" />
            <Button Content="새로고침" Padding="12,6" />
            <TextBox x:Name="SearchBox" Width="260" Margin="16,0,0,0" VerticalContentAlignment="Center" />
            <Button Content="검색" Padding="12,6" Click="SearchButton_Click" />
            <Button x:Name="FavoriteButton" Content="즐겨찾기" Padding="12,6" Click="FavoriteButton_Click" />
            <Separator />
            <TextBlock x:Name="RepositoryPathText"
                       Foreground="#555"
                       VerticalAlignment="Center"
                       Text="저장소가 선택되지 않았습니다." />
        </ToolBar>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D8D8D2"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="차량 문서"
                               FontWeight="SemiBold"
                               Margin="12,10" />
                    <TextBlock x:Name="DocumentScanStatusText"
                               DockPanel.Dock="Bottom"
                               Foreground="#666"
                               Margin="12,6"
                               Text="스캔 대기 중" />
                    <StackPanel DockPanel.Dock="Bottom" Margin="8,4,8,8">
                        <TextBlock Text="최근 본 차량"
                                   FontWeight="SemiBold"
                                   Margin="4,4" />
                        <ListBox x:Name="RecentVehiclesList"
                                 MaxHeight="130"
                                 BorderThickness="0"
                                 SelectionChanged="RecentVehiclesList_SelectionChanged" />
                        <TextBlock Text="즐겨찾기"
                                   FontWeight="SemiBold"
                                   Margin="4,10,4,4" />
                        <ListBox x:Name="FavoriteVehiclesList"
                                 MaxHeight="130"
                                 BorderThickness="0"
                                 SelectionChanged="FavoriteVehiclesList_SelectionChanged" />
                    </StackPanel>
                    <TreeView x:Name="VehicleTree" Margin="8,0,8,8" SelectedItemChanged="VehicleTree_SelectedItemChanged" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" />

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D8D8D2"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock x:Name="VehicleReadTitle"
                               DockPanel.Dock="Top"
                               Text="차량 정보"
                               FontWeight="SemiBold"
                               Margin="12,10" />
                    <TextBlock x:Name="KeyOptionSummaryText"
                               DockPanel.Dock="Top"
                               Foreground="#345"
                               Background="#FFFADC"
                               Padding="8,4"
                               Margin="12,0,12,8"
                               Text="핵심 옵션 키워드가 여기에 표시됩니다."
                               TextWrapping="Wrap" />
                    <TextBox x:Name="MarkdownEditor"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="14"
                             HorizontalScrollBarVisibility="Auto"
                             TextChanged="MarkdownEditor_TextChanged"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             Visibility="Collapsed" />
                    <ScrollViewer x:Name="VehicleReadScroll"
                                  Margin="12,0,12,12"
                                  VerticalScrollBarVisibility="Auto">
                        <FlowDocumentScrollViewer x:Name="VehicleReadDocumentViewer">
                            <FlowDocument FontSize="15" LineHeight="24">
                                <Paragraph>왼쪽에서 차량 문서를 선택하세요.</Paragraph>
                            </FlowDocument>
                        </FlowDocumentScrollViewer>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="8" HorizontalAlignment="Stretch" />

            <Border Grid.Column="4"
                    Background="White"
                    BorderBrush="#D8D8D2"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock x:Name="SearchResultsTitle"
                               DockPanel.Dock="Top"
                               Text="검색 결과"
                               FontWeight="SemiBold"
                               Margin="12,10" />
                    <ListBox x:Name="SearchResultsList"
                             BorderThickness="0"
                             Margin="8,0,8,8"
                             SelectionChanged="SearchResultsList_SelectionChanged" />
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
