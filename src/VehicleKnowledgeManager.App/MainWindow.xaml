<Window x:Class="CarWikipedia.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Car Wikipedia"
        Height="720"
        MinHeight="560"
        Width="1180"
        MinWidth="900">
    <DockPanel Background="#F7F7F5">
        <ToolBar DockPanel.Dock="Top" Padding="8,6">
            <Button Content="저장소 열기" Padding="12,6" Click="OpenRepositoryButton_Click" />
            <Button Content="새 문서" Padding="12,6" />
            <Button Content="새 폴더" Padding="12,6" />
            <Button Content="DOCX 가져오기" Padding="12,6" />
            <Separator />
            <Button Content="저장" Padding="12,6" />
            <Button Content="새로고침" Padding="12,6" />
            <TextBox Width="260" Margin="16,0,0,0" VerticalContentAlignment="Center" />
            <Button Content="검색" Padding="12,6" />
            <Separator />
            <TextBlock x:Name="RepositoryPathText"
                       Foreground="#555"
                       VerticalAlignment="Center"
                       Text="저장소가 선택되지 않았습니다." />
        </ToolBar>

        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D8D8D2"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="차량 문서"
                               FontWeight="SemiBold"
                               Margin="12,10" />
                    <TextBlock x:Name="DocumentScanStatusText"
                               DockPanel.Dock="Bottom"
                               Foreground="#666"
                               Margin="12,6"
                               Text="스캔 대기 중" />
                    <TreeView x:Name="VehicleTree" Margin="8,0,8,8" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" />

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D8D8D2"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Markdown 편집기"
                               FontWeight="SemiBold"
                               Margin="12,10" />
                    <TextBox AcceptsReturn="True"
                             AcceptsTab="True"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="14"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="8" HorizontalAlignment="Stretch" />

            <Border Grid.Column="4"
                    Background="White"
                    BorderBrush="#D8D8D2"
                    BorderThickness="1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="미리보기"
                               FontWeight="SemiBold"
                               Margin="12,10" />
                    <ScrollViewer Margin="12,0,12,12">
                        <TextBlock Text="Markdown 렌더러 연결 전 기본 준비 화면입니다."
                                   Foreground="#666"
                                   TextWrapping="Wrap" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
